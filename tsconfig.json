{
  "compilerOptions": {
    "target": "ES2020",           // 现代浏览器支持 ES2020
    "module": "ESNext",
    "strict": true,               // 开启严格模式，强制处理 null
    "noEmitOnError": true,
    "outDir": "./dist",           // 编译后的 JS 放在 dist 文件夹
    "rootDir": "./src",           // 源码放在 src 文件夹
    "moduleResolution": "node",
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}