{
  "manifest_version": 3,
  "name": "B站增强",
  "version": "3.0",
  "description": "B站体验增强工具：集成视频旋转、快捷截图(Shift+S)、毫秒级时间显示，以及全局视频列表的封面大图预览功能。",
  "icons": {
    "16": "icons/faviconV2.png",
    "48": "icons/faviconV2.png",
    "128": "icons/faviconV2.png"
  },
  "permissions": [
    "storage" 
  ],
  "host_permissions": [
    "*://api.bilibili.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "32": "icons/faviconV2.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.bilibili.com/video/*",
        "*://www.bilibili.com/bangumi/play/*",
        "*://www.bilibili.com/list/*",

        "*://www.bilibili.com/watchlater/*", 
        "*://space.bilibili.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}