{
  "manifest_version": 3,
  "name": "B站增强",
  "version": "3.0",
  "description": "整合了视频旋转、截图(Shift+S)、毫秒级时间显示功能。",
  "icons": {
    "32": "icons/faviconV2.png"
  },
  "permissions": [
    "storage" 
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "32": "icons/faviconV2.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.bilibili.com/video/*",
        "*://www.bilibili.com/bangumi/play/*",
        "*://www.bilibili.com/list/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}